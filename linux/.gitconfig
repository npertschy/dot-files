[core]
	autocrlf = input
    pager = delta

[fetch]
    prune = true

[pull]
    rebase = false

[interactive]
    diffFilter = delta --color-only

[delta]
    dark = true
    syntax-theme = OneHalfDark
    navigate = true
    line-numbers = true
    side-by-side = true

    minus-style      = syntax "#3b1f2b"
    minus-emph-style = bold "#ff8b9a" "#5c2333"
    plus-style       = syntax "#1e3829"
    plus-emph-style  = bold "#b5e890" "#27502f"

    line-numbers-minus-style = "#e06c75"
    line-numbers-plus-style  = "#98c379"
    line-numbers-zero-style  = "#4b5263"

    features = decorations

[delta "decorations"]
    file-decoration-style = blue ol ul
    file-style = bold purple
    file-added-label = "  +"
    file-modified-label = "  ~"
    file-removed-label = "  -"
    file-renamed-label = "  →"
    file-copied-label = "  ="    
    hunk-header-style = omit

[merge]
    conflictStyle = zdiff3

[credential]
	helper = /mnt/c/Program\\ Files/Git/mingw64/bin/git-credential-manager.exe

[user]
	email = nikolas.pertschy@dataciders.com
	name = Nikolas Pertschy
