+T["GitHub Enterprise"]["token cache is invalidated when switching from public to GHE"] = function()
+  local result = token_child.lua([[
+    local token = require("codecompanion.adapters.http.copilot.token")
+
+    -- Call resolve_endpoints for GHE adapter to get the expected hostname
+    local ghe_adapter = { env = { github_enterprise_url = "ghe.mycompany.com" } }
+    local _, ghe_hostname = token.resolve_endpoints(ghe_adapter)
+
+    -- Simulate cached tokens for public github
+    token._oauth_token = "public_oauth_token"
+    token._copilot_token = { token = "public_copilot_token", expires_at = os.time() + 3600 }
+    token._cached_host = "github.com"
+
+    -- The invalidation logic in get_oauth_token checks _cached_host vs auth_hostname.
+    -- Verify the cached host differs from the GHE hostname (prerequisite for invalidation).
+    local hosts_differ = (token._cached_host ~= ghe_hostname)
+
+    -- Simulate the invalidation: if hosts differ and a token is cached, it should be cleared.
+    -- This mirrors the logic in get_oauth_token before attempting a fresh fetch.
+    if token._oauth_token and token._cached_host ~= ghe_hostname then
+      token._oauth_token = nil
+      token._copilot_token = nil
+    end
+
+    local invalidated = (token._oauth_token == nil and token._copilot_token == nil)
+
+    return {
+      hosts_differ = hosts_differ,
+      invalidated = invalidated,
+      ghe_hostname = ghe_hostname,
+    }
+  ]])
+  h.eq(true, result.hosts_differ)
+  h.eq(true, result.invalidated)
+  h.eq("ghe.mycompany.com", result.ghe_hostname)
+end
